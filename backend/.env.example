# Server configuration
PORT=5000
NODE_ENV=development

# Database configuration
# Set your MongoDB Atlas Connection URI
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/chatcode?retryWrites=true&w=majority

# JWT configuration
JWT_SECRET=your_jwt_secret_key_change_me_in_production

# Cloudinary credentials (for image, video, file uploads)
# If left blank, server will automatically mock uploads and return Data URIs
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Client Url (cors setup)
CLIENT_URL=http://localhost:5173
